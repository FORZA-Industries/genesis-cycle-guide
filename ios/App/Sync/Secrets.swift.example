// Secrets.swift.example
// Target path: App/Genesyx/Sync/Secrets.swift.example  (committed)
// The real Secrets.swift is GITIGNORED and generated at build time (§6.2).
//
// Generation (add as an xcodegen preBuildScript in project.yml):
//
//   preBuildScripts:
//     - name: Generate Secrets
//       script: |
//         SECRETS="${SRCROOT}/App/Genesyx/Sync/Secrets.swift"
//         cat > "$SECRETS" <<EOF
//         // AUTO-GENERATED — do not edit, do not commit.
//         enum Secrets {
//             static let supabaseURL = "${SUPABASE_URL}"
//             static let supabaseAnonKey = "${SUPABASE_ANON_KEY}"
//             static let googleClientID = "${GOOGLE_IOS_CLIENT_ID}"
//         }
//         EOF
//       outputFiles:
//         - $(SRCROOT)/App/Genesyx/Sync/Secrets.swift
//
// .gitignore must contain:  App/Genesyx/Sync/Secrets.swift
//
// Empty values → the app runs on today's local stubs (unchanged behaviour), so
// simulators and CI keep working with no env configured.

enum Secrets {
    /// e.g. "https://<project-ref>.supabase.co" — empty string = stub mode.
    static let supabaseURL = ""
    /// The ANON (publishable) key only. The service-role key must NEVER appear
    /// in the app (§8) — it lives exclusively in the delete-account Edge Function.
    static let supabaseAnonKey = ""
    /// iOS OAuth client ID from Google Cloud (checklist §9.8). Empty = the
    /// Google button reports "not configured", exactly as today.
    static let googleClientID = ""
}
